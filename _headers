# Netlify production headers for The Food Gap.
# Keep index/data fresh; cache only vendored library assets long-term.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.basemaps.cartocdn.com; connect-src 'self' https://*.basemaps.cartocdn.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

/canada.js
  Cache-Control: no-cache

/robots.txt
  Cache-Control: no-cache

/sitemap.xml
  Cache-Control: no-cache

/LICENCES.md
  Cache-Control: no-cache

/PRIVACY.md
  Cache-Control: no-cache

/maplibre-gl.js
  Cache-Control: public, max-age=31536000, immutable

/maplibre-gl.css
  Cache-Control: public, max-age=31536000, immutable

/og-image.png
  Cache-Control: public, max-age=31536000, immutable

/apple-touch-icon.png
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable
